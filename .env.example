# .env.example
# Vercel等の本番環境またはローカル開発環境で必要な環境変数一覧

# -----------------
# 認証用 (Basic認証)
# -----------------
# /admin-*.html へのアクセスに必要なIDとパスワード
ADMIN_USER=your_secure_user_name
ADMIN_PASS=your_secure_password_here

# -----------------
# microCMS連携用
# -----------------
# microCMSのサービスドメイン (例: https://{YOUR_DOMAIN}.microcms.io)
VITE_MICROCMS_SERVICE_DOMAIN=with-sasayama

# 【統合APIキー】(無料プラン向け設定)
# 管理画面での記事保存（POST権限）と、フロントエンドでの記事表示（GET権限）の両方を持つ一つのキー。
# セキュリティ確保のため、VITE_ から始まる変数には絶対に設定せず、Vercelのバックエンドプロキシでのみ読み取らせます。
# microCMSの管理画面で「default」キーにGETとPOST（さらにあればPATCH）権限を両方付与し、その値を以下に設定してください。
MICROCMS_API_KEY=your_single_powerful_api_key_here

# 【マネジメントAPIキー】(画像アップロード用)
# 画像などメディアファイルをmicroCMSへ保存するための専用キー。
# microCMS管理画面の右上アイコン > 「マネジメントAPI」から作成し、ここにセットしてください。
MICROCMS_MANAGEMENT_KEY=your_management_api_key_here

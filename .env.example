# .env.example
# Vercel等の本番環境またはローカル開発環境で必要な環境変数一覧

# -----------------
# 認証用 (Basic認証)
# -----------------
# /admin-*.html へのアクセスに必要なIDとパスワード
ADMIN_USER=your_secure_user_name
ADMIN_PASS=your_secure_password_here

# -----------------
# microCMS連携用
# -----------------
# microCMSのサービスドメイン (例: https://{YOUR_DOMAIN}.microcms.io)
VITE_MICROCMS_SERVICE_DOMAIN=with-sasayama

# 【閲覧専用】フロントエンドでサイトを表示するためのAPIキー (GET権限のみを付与してください)
VITE_MICROCMS_API_KEY=your_read_only_api_key_here

# 【書込専用】管理画面から記事を直接保存するためのAPIキー (POST権限を付与してください)
# セキュリティ上、VITE_ をつけずに定義し、JavaScript(ブラウザ)に絶対に漏洩させない設定にします。
MICROCMS_WRITE_API_KEY=your_write_only_api_key_here
